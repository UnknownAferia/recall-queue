DISCORD_TOKEN=your_vora_core_bot_token
DISCORD_CLIENT_ID=your_vora_core_application_id
DISCORD_GUILD_IDS=first_guild_id,second_guild_id

VORA_COMMUNITY_DISCORD_TOKEN=your_vora_community_bot_token
VORA_COMMUNITY_DISCORD_CLIENT_ID=your_vora_community_application_id

