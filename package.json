{
  "name": "recallq",
  "version": "2.0.0",
  "description": "Discord-based competitive matchmaking system for Mobile Legends",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "deploy": "tsx src/scripts/deployCommands.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src",
    "format": "prettier --write \"src/**/*.ts\""
  },
  "keywords": [
    "discord",
    "mobile-legends",
    "matchmaking",
    "mmr"
  ],
  "author": "Raphael Schäublin",
  "license": "MIT",
  "dependencies": {
    "discord.js": "^14.27.0",
    "dotenv": "^17.4.2",
    "mongoose": "^9.7.4",
    "winston": "^3.19.0"
  },
  "devDependencies": {
    "@types/node": "^26.1.1",
    "eslint": "^10.7.0",
    "prettier": "^3.9.5",
    "tsx": "^4.23.1",
    "typescript": "^7.0.2"
  }
}